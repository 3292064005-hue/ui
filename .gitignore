# ==========================================
# Spine Ultrasound Platform .gitignore
# ==========================================

# 1. C++ & CMake Build Artifacts
cpp_robot_core/build/
build/
CMakeCache.txt
CMakeFiles/
CMakeScripts/
Makefile
cmake_install.cmake
install/
*.o
*.obj
*.so
*.dylib
*.dll
*.a
*.lib
*.exe
*.out
*.app

# 2. Python Environments & Caches
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
.env
.pytest_cache/
.coverage
htmlcov/
dist/
spine_ultrasound_workspace/

# 3. IDEs & Editors
.vscode/
.idea/
*.swp
*~
.DS_Store

# 4. Logs, Artifacts & Session Data
# (Crucial: Prevents uploading giant HDF5 and log files to git)
logs/
data/
*.h5
*.hdf5
*.log
*.pcd
*.ply
*.mp4
*.avi
*.png
*.jpg

# 5. Temporary Development/Extraction Files
pdf_content.txt
pdf_content_utf8.txt
sdk_manual.txt
