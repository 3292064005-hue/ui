{
  "$id": "camera_frame_envelope.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "frame_id",
    "device_id",
    "timestamp_ns",
    "frame_type",
    "resolution",
    "intrinsics_hash",
    "storage_ref",
    "fresh",
    "provider_mode"
  ],
  "properties": {
    "frame_id": {"type": "string", "minLength": 1},
    "device_id": {"type": "string", "minLength": 1},
    "timestamp_ns": {"type": "integer", "minimum": 1},
    "frame_type": {"type": "string", "enum": ["rgb", "depth", "rgbd"]},
    "resolution": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "intrinsics_hash": {"type": "string", "minLength": 1},
    "storage_ref": {"type": "string", "minLength": 1},
    "fresh": {"type": "boolean"},
    "provider_mode": {"type": "string", "enum": ["synthetic", "filesystem", "opencv_camera", "realsense_d435i"]},
    "depth_storage_ref": {"type": "string", "minLength": 1},
    "stream_roles": {"type": "array", "items": {"type": "string", "enum": ["color", "depth"]}, "minItems": 1},
    "depth_unit": {"type": "string", "minLength": 1},
    "depth_valid_ratio": {"type": "number", "minimum": 0, "maximum": 1},
    "depth_median_mm": {"type": "number"},
    "depth_resolution": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "intrinsics": {"type": "object"}
  },
  "additionalProperties": false
}
