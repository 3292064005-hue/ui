[Unit]
Description=Spine Ultrasound Platform Ubuntu 22.04 headless backend
After=spine-cpp-core.service

[Service]
Type=simple
WorkingDirectory=/opt/spine_ultrasound
ExecStart=/opt/spine_ultrasound/.venv/bin/uvicorn spine_ultrasound_ui.api_server:app --host 0.0.0.0 --port 8000

# Do NOT pin to isolated CPUs 0,1. Default system scheduler handles Python on remaining cores (2-15)
CPUSchedulingPolicy=other
Restart=always
RestartSec=2s

[Install]
WantedBy=spine-ultrasound.target
