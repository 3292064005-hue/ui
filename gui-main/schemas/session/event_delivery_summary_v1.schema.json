{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Event Delivery Summary",
  "type": "object",
  "required": [
    "generated_at",
    "session_id",
    "summary"
  ],
  "properties": {
    "generated_at": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "summary": {
      "type": "object"
    },
    "continuity_gaps": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "delivery_classes": {
      "type": "object"
    },
    "resume_outcome_summary": {
      "type": "object"
    },
    "contract_consistency_summary": {
      "type": "object"
    }
  },
  "additionalProperties": true
}