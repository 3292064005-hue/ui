{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Contract Kernel Diff",
  "type": "object",
  "required": ["session_id", "service_version", "summary", "checks", "diffs"],
  "properties": {
    "session_id": {"type": "string"},
    "service_version": {"type": "string"},
    "schema": {"type": "string"},
    "summary": {
      "type": "object",
      "required": ["consistent", "diff_count", "checked_object_count"],
      "properties": {
        "consistent": {"type": "boolean"},
        "diff_count": {"type": "integer"},
        "checked_object_count": {"type": "integer"}
      }
    },
    "checks": {"type": "object", "additionalProperties": {"type": "boolean"}},
    "diffs": {"type": "array", "items": {"type": "object"}}
  }
}
