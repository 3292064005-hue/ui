  </transmission>





<!--link 6--> 
  <link name="${nameofManipulator}_link6">
    <visual>
      <geometry>
        <mesh filename="package://${nameofManipulator}_description/meshes/visual/${nameofManipulator}_link6.stl" scale="0.001 0.001 0.001"/>
      </geometry>
	<origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <material name="white"/>
